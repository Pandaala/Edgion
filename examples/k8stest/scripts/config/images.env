# K8s integration image config (single source of truth)
# Priority in run_k8s_integration.sh:
#   1) Explicit env CONTROLLER_IMAGE / GATEWAY_IMAGE / TEST_CLIENT_IMAGE / TEST_SERVER_IMAGE
#   2) values in this file (same vars)
#   3) compose from IMAGE_REGISTRY/IMAGE_NAMESPACE/IMAGE_VERSION/IMAGE_ARCH

IMAGE_REGISTRY=docker.io
IMAGE_NAMESPACE=pandaala
IMAGE_VERSION=v0.1.1
IMAGE_ARCH=arm64

# Prefer setting explicit full image refs for remote clusters.
# CONTROLLER_IMAGE=docker.io/pandaala/edgion-controller:v0.1.1_amd64
# GATEWAY_IMAGE=docker.io/pandaala/edgion-gateway:v0.1.1_amd64
# TEST_CLIENT_IMAGE=docker.io/pandaala/edgion-test-client:v0.1.1-k8s
# TEST_SERVER_IMAGE=docker.io/pandaala/edgion-test-server:v0.1.1-k8s
