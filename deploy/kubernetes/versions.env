# Default image versions for deploy scripts.
# Environment variables CONTROLLER_IMAGE / GATEWAY_IMAGE take precedence.

EDGION_VERSION="0.1.6"

DEFAULT_CONTROLLER_IMAGE="docker.io/pandaala/edgion-controller:${EDGION_VERSION}"
DEFAULT_GATEWAY_IMAGE="docker.io/pandaala/edgion-gateway:${EDGION_VERSION}"
