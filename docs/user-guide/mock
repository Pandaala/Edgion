## 完整示例

### 开发环境 API 原型

```yaml
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: api-prototype
  namespace: default
spec:
  parentRefs:
    - name: dev-gateway
  hostnames:
    - "api-dev.example.com"
  rules:
    # GET /api/users - 用户列表
    - matches:
        - path:
            type: Exact
            value: /api/users
          method: GET
      filters:
        - type: ExtensionRef
          extensionRef:
            group: edgion.io
            kind: EdgionPlugins
            name: mock-users-list

    # POST /api/users - 创建用户
    - matches:
        - path:
            type: Exact
            value: /api/users
          method: POST
      filters:
        - type: ExtensionRef
          extensionRef:
            group: edgion.io
            kind: EdgionPlugins
            name: mock-user-create

    # GET /api/users/:id - 用户详情
    - matches:
        - path:
            type: PathPrefix
            value: /api/users/
          method: GET
      filters:
        - type: ExtensionRef
          extensionRef:
            group: edgion.io
            kind: EdgionPlugins
            name: mock-user-detail

    # DELETE /api/users/:id - 删除用户
    - matches:
        - path:
            type: PathPrefix
            value: /api/users/
          method: DELETE
      filters:
        - type: ExtensionRef
          extensionRef:
            group: edgion.io
            kind: EdgionPlugins
            name: mock-user-delete
---
apiVersion: edgion.io/v1
kind: EdgionPlugins
metadata:
  name: mock-users-list
spec:
  plugins:
    - enable: true
      plugin:
        type: Mock
        config:
          statusCode: 200
          body: |
            {
              "users": [
                {"id": 1, "name": "Alice", "email": "alice@example.com"},
                {"id": 2, "name": "Bob", "email": "bob@example.com"}
              ],
              "total": 2
            }
          headers:
            X-Total-Count: "2"
---
apiVersion: edgion.io/v1
kind: EdgionPlugins
metadata:
  name: mock-user-create
spec:
  plugins:
    - enable: true
      plugin:
        type: Mock
        config:
          statusCode: 201
          body: |
            {
              "id": 3,
              "name": "Charlie",
              "email": "charlie@example.com",
              "created_at": "2024-03-15T10:00:00Z"
            }
          headers:
            Location: "/api/users/3"
---
apiVersion: edgion.io/v1
kind: EdgionPlugins
metadata:
  name: mock-user-detail
spec:
  plugins:
    - enable: true
      plugin:
        type: Mock
        config:
          statusCode: 200
          body: |
            {
              "id": 1,
              "name": "Alice",
              "email": "alice@example.com",
              "created_at": "2024-01-01T00:00:00Z",
              "updated_at": "2024-03-15T10:00:00Z"
            }
---
apiVersion: edgion.io/v1
kind: EdgionPlugins
metadata:
  name: mock-user-delete
spec:
  plugins:
    - enable: true
      plugin:
        type: Mock
        config:
          statusCode: 204
```

**测试命令**：

```bash
# 获取用户列表
curl https://api-dev.example.com/api/users

# 创建用户
curl -X POST https://api-dev.example.com/api/users \
  -H "Content-Type: application/json" \
  -d '{"name":"Charlie","email":"charlie@example.com"}'

# 获取用户详情
curl https://api-dev.example.com/api/users/1

# 删除用户
curl -X DELETE https://api-dev.example.com/api/users/1
```

